{
  "rewrites": [
    { "source": "/api/auth",            "destination": "/api/auth" },
    { "source": "/api/anthropic/(.*)", "destination": "/api/anthropic" },
    { "source": "/api/email",           "destination": "/api/email" },
    { "source": "/api/whatsapp",        "destination": "/api/whatsapp" },
    { "source": "/(.*)",                "destination": "/index.html" }
  ]
}
