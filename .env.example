# HisaabHub / ClaimX Environment Variables
# Copy this file to .env and fill in your values

# Supabase (get from: Supabase Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic API Key for invoice OCR (get from: console.anthropic.com)
# In development: used via Vite proxy (CORS handled automatically)
# In production: move this to a Netlify/server function - do NOT expose in frontend
VITE_ANTHROPIC_KEY=sk-ant-...your-key-here...
